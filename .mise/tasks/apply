#!/usr/bin/env bash
#MISE description="Apply hooks from the catalog to Claude Code settings"
#USAGE arg "[hooks...]" help="Hook names to apply (e.g., session-id anti-compact). If none specified, applies all."
#USAGE flag "--dry-run" help="Show what would change without applying"
#USAGE flag "--scope <scope>" default="user" help="Settings scope: user, project, or local"

set -eu

DRY_RUN="${usage_dry_run:-false}"
SCOPE="${usage_scope:-user}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
CATALOG_DIR="$REPO_DIR/catalog"

case "$SCOPE" in
  user)    SETTINGS_FILE="$HOME/.claude/settings.json" ;;
  project) SETTINGS_FILE="${CALLER_PWD:-.}/.claude/settings.json" ;;
  local)   SETTINGS_FILE="${CALLER_PWD:-.}/.claude/settings.local.json" ;;
  *)       echo "Error: scope must be user, project, or local" >&2; exit 1 ;;
esac

# Collect catalog files to apply
CATALOG_FILES=()
HOOKS="${usage_hooks:-}"
if [ -n "$HOOKS" ]; then
  for NAME in $HOOKS; do
    FILE="$CATALOG_DIR/${NAME}.json"
    if [ ! -f "$FILE" ]; then
      echo "Error: No catalog entry for '$NAME' (expected $FILE)" >&2
      exit 1
    fi
    CATALOG_FILES+=("$FILE")
  done
else
  for f in "$CATALOG_DIR"/*.json; do
    CATALOG_FILES+=("$f")
  done
fi

if [ ${#CATALOG_FILES[@]} -eq 0 ]; then
  echo "No hooks to apply" >&2
  exit 0
fi

# Ensure settings file exists
if [ ! -f "$SETTINGS_FILE" ]; then
  echo "{}" > "$SETTINGS_FILE"
fi

CURRENT_HOOKS=$(jq '.hooks // {}' "$SETTINGS_FILE")

# Check each catalog entry: unchanged (skip), updated (replace), or new (add)
SKIP_FILES=()    # catalog files where the exact command already exists
UPDATE_FILES=()  # catalog files where the marker exists but command changed
NEW_FILES=()     # catalog files with no existing marker

for f in "${CATALOG_FILES[@]}"; do
  NAME=$(jq -r '.name' "$f")
  MARKER="# hookers:${NAME}"
  # NOTE: assumes each catalog entry has one hook. Multi-hook entries would
  # need to compare all commands; the marker fallback handles this correctly.
  CMD=$(jq -r '.hooks | to_entries[0].value[0].hooks[0].command' "$f")

  # Check if exact command already exists in settings
  EXACT=$(echo "$CURRENT_HOOKS" | jq --arg cmd "$CMD" '
    [to_entries[] | .value[] | .hooks[] | select(.command == $cmd)] | length
  ' 2>/dev/null)

  if [ "$EXACT" -gt 0 ]; then
    SKIP_FILES+=("$f")
  else
    # Check if marker exists (means command changed)
    HAS_MARKER=$(echo "$CURRENT_HOOKS" | jq --arg marker "$MARKER" '
      [to_entries[] | .value[] | .hooks[] | select(.command | contains($marker))] | length
    ' 2>/dev/null)
    if [ "$HAS_MARKER" -gt 0 ]; then
      UPDATE_FILES+=("$f")
    else
      NEW_FILES+=("$f")
    fi
  fi
done

ALREADY=${#SKIP_FILES[@]}
UPDATED=${#UPDATE_FILES[@]}
NEW=${#NEW_FILES[@]}

if [ "$((UPDATED + NEW))" -eq 0 ]; then
  echo "All hooks up to date ($ALREADY present)" >&2
  exit 0
fi

if [ "$DRY_RUN" = "true" ]; then
  for f in "${UPDATE_FILES[@]}"; do
    NAME=$(jq -r '.name' "$f")
    echo "Would update: $NAME" >&2
  done
  for f in "${NEW_FILES[@]}"; do
    NAME=$(jq -r '.name' "$f")
    echo "Would add: $NAME" >&2
  done
  echo "$((UPDATED + NEW)) hook(s) to apply ($NEW new, $UPDATED updated), $ALREADY already present" >&2
  exit 0
fi

# Remove outdated hooks (ones with matching marker but different command)
for f in "${UPDATE_FILES[@]}"; do
  NAME=$(jq -r '.name' "$f")
  MARKER="# hookers:${NAME}"
  jq --arg marker "$MARKER" '
    .hooks //= {} |
    .hooks = (.hooks | to_entries | map(
      .value = [.value[] |
        .hooks = [.hooks[] | select(.command | contains($marker) | not)] |
        select((.hooks | length) > 0)
      ] | select((.value | length) > 0)
    ) | from_entries) |
    if (.hooks | length) == 0 then del(.hooks) else . end
  ' "$SETTINGS_FILE" > "${SETTINGS_FILE}.tmp" && mv "${SETTINGS_FILE}.tmp" "$SETTINGS_FILE"
done

# Build merged hooks object from new + updated catalog entries
APPLY_FILES=("${UPDATE_FILES[@]}" "${NEW_FILES[@]}")
DESIRED_HOOKS=$(jq -s '
  reduce .[] as $entry ({};
    reduce ($entry.hooks | keys[]) as $event (.;
      .[$event] = (.[$event] // []) + $entry.hooks[$event]
    )
  )
' "${APPLY_FILES[@]}")

# Clean up temp file on failure
trap 'rm -f "${SETTINGS_FILE}.tmp"' ERR

jq --argjson desired "$DESIRED_HOOKS" '
  .hooks //= {} |
  reduce ($desired | keys[]) as $event (.;
    reduce ($desired[$event] | to_entries[]) as $group (.;
      ($group.value.matcher) as $matcher |
      reduce ($group.value.hooks[] ) as $hook (.;
        if (.hooks[$event] // [] | [.[] | select(.matcher == $matcher) | .hooks[] | select(.command == $hook.command)] | length) > 0
        then .
        else
          if (.hooks[$event] // [] | [to_entries[] | select(.value.matcher == $matcher)] | length) > 0
          then
            .hooks[$event] = [.hooks[$event][] | if .matcher == $matcher then .hooks += [$hook] else . end]
          else
            .hooks[$event] = (.hooks[$event] // []) + [{"matcher": $matcher, "hooks": [$hook]}]
          end
        end
      )
    )
  )
' "$SETTINGS_FILE" > "${SETTINGS_FILE}.tmp" \
  && mv "${SETTINGS_FILE}.tmp" "$SETTINGS_FILE"

echo "Applied $((UPDATED + NEW)) hook(s) ($NEW new, $UPDATED updated), $ALREADY already present" >&2
