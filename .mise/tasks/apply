#!/usr/bin/env bash
#MISE description="Apply hooks from the catalog as a pi extension"
#USAGE arg "[hooks...]" help="Hook names to apply (e.g., dashboard anti-compact). If none specified, applies all."
#USAGE flag "--dry-run" help="Show what would change without applying"
#USAGE flag "--catalog <path>" var=#true help="Additional catalog directories to search"
#USAGE flag "--extension-dir <dir>" help="Pi extension directory (default: ~/.pi/agent/extensions)"

set -euo pipefail

DRY_RUN="${usage_dry_run:-false}"
EXT_DIR="${usage_extension_dir:-$HOME/.pi/agent/extensions}"
STATE_DIR="${HOOKERS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/hookers}"
STATE_FILE="$STATE_DIR/applied.json"

# Build list of catalog directories
CATALOG_DIRS=("${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}/catalog")
if [ -n "${usage_catalog:-}" ]; then
  for dir in $usage_catalog; do
    if [ ! -d "$dir" ]; then
      echo "Error: Catalog directory '$dir' does not exist" >&2
      exit 1
    fi
    CATALOG_DIRS+=("$dir")
  done
fi

# Collect catalog files to apply
CATALOG_FILES=()
HOOKS="${usage_hooks:-}"
if [ -n "$HOOKS" ]; then
  for NAME in $HOOKS; do
    FOUND=""
    for dir in "${CATALOG_DIRS[@]}"; do
      FILE="$dir/${NAME}.json"
      if [ -f "$FILE" ]; then
        FOUND="$FILE"
        break
      fi
    done
    if [ -z "$FOUND" ]; then
      SEARCHED=$(printf ", %s" "${CATALOG_DIRS[@]}")
      echo "Error: No catalog entry for '$NAME' (searched:${SEARCHED:1})" >&2
      exit 1
    fi
    CATALOG_FILES+=("$FOUND")
  done
else
  for dir in "${CATALOG_DIRS[@]}"; do
    for f in "$dir"/*.json; do
      [ -f "$f" ] && CATALOG_FILES+=("$f")
    done
  done
fi

if [ ${#CATALOG_FILES[@]} -eq 0 ]; then
  echo "No hooks to apply" >&2
  exit 0
fi

# Validate catalog entries have required fields
for f in "${CATALOG_FILES[@]}"; do
  NAME=$(jq -r '.name // empty' "$f")
  ON=$(jq -r '.on // empty' "$f")
  ACTION=$(jq -r '.action // empty' "$f")
  if [ -z "$NAME" ] || [ -z "$ON" ] || [ -z "$ACTION" ]; then
    echo "Error: Invalid catalog entry $f (missing name, on, or action)" >&2
    exit 1
  fi
done

# Load current state
mkdir -p "$STATE_DIR"
if [ ! -f "$STATE_FILE" ]; then
  echo '{"applied":[]}' > "$STATE_FILE"
fi

CURRENTLY_APPLIED=$(jq -r '.applied[].name' "$STATE_FILE" 2>/dev/null || true)

# Determine what's new vs already applied
NEW_FILES=()
EXISTING_NAMES=()
for f in "${CATALOG_FILES[@]}"; do
  NAME=$(jq -r '.name' "$f")
  if echo "$CURRENTLY_APPLIED" | grep -qx "$NAME" 2>/dev/null; then
    EXISTING_NAMES+=("$NAME")
  else
    NEW_FILES+=("$f")
  fi
done

NEW=${#NEW_FILES[@]}
EXISTING=${#EXISTING_NAMES[@]}

if [ "$DRY_RUN" = "true" ]; then
  for f in ${NEW_FILES[@]+"${NEW_FILES[@]}"}; do
    echo "Would add: $(jq -r '.name' "$f")" >&2
  done
  for name in ${EXISTING_NAMES[@]+"${EXISTING_NAMES[@]}"}; do
    echo "Already applied: $name" >&2
  done
  echo "$NEW to add, $EXISTING already applied" >&2
  exit 0
fi

# Build speculative state file with new hooks added
SPEC_STATE="${STATE_FILE}.pending"
cp "$STATE_FILE" "$SPEC_STATE"
for f in ${NEW_FILES[@]+"${NEW_FILES[@]}"}; do
  NAME=$(jq -r '.name' "$f")
  CATALOG_DIR=$(cd "$(dirname "$f")" && pwd)
  jq --arg name "$NAME" --arg catalog "$CATALOG_DIR" \
    '.applied += [{"name": $name, "catalog": $catalog}]' \
    "$SPEC_STATE" > "${SPEC_STATE}.tmp" && mv "${SPEC_STATE}.tmp" "$SPEC_STATE"
done

# Generate extension first — if this fails, state is unchanged
mkdir -p "$EXT_DIR"
trap 'rm -f "$EXT_DIR/hookers.ts.tmp" "$SPEC_STATE" "${SPEC_STATE}.tmp"' ERR
bash "$MISE_CONFIG_ROOT/scripts/generate-extension.sh" "$SPEC_STATE" \
  > "$EXT_DIR/hookers.ts.tmp"

# Extension generated successfully — commit state and extension
mv "$SPEC_STATE" "$STATE_FILE"
mv "$EXT_DIR/hookers.ts.tmp" "$EXT_DIR/hookers.ts"

if [ "$NEW" -gt 0 ]; then
  echo "Applied $NEW hook(s) ($EXISTING already present)" >&2
else
  echo "All hooks up to date ($EXISTING present), extension regenerated" >&2
fi
