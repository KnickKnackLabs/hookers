#!/usr/bin/env bash
#MISE description="Remove applied hooks"
#USAGE arg "<hooks...>" help="Hook names to remove (e.g., dashboard anti-compact)"
#USAGE flag "--dry-run" help="Show what would change without removing"
#USAGE flag "--extension-dir <dir>" help="Pi extension directory (default: ~/.pi/agent/extensions)"

set -euo pipefail

DRY_RUN="${usage_dry_run:-false}"
EXT_DIR="${usage_extension_dir:-$HOME/.pi/agent/extensions}"
STATE_DIR="${HOOKERS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/hookers}"
STATE_FILE="$STATE_DIR/applied.json"
HOOKS="$usage_hooks"

if [ ! -f "$STATE_FILE" ]; then
  echo "No hooks applied" >&2
  exit 0
fi

REMOVED=0

for NAME in $HOOKS; do
  IS_APPLIED=$(jq --arg name "$NAME" '[.applied[] | select(.name == $name)] | length' "$STATE_FILE")

  if [ "$IS_APPLIED" -eq 0 ]; then
    echo "Hook '$NAME' is not applied" >&2
    continue
  fi

  if [ "$DRY_RUN" = "true" ]; then
    echo "Would remove: $NAME" >&2
    REMOVED=$((REMOVED + 1))
    continue
  fi

  # Remove from state
  jq --arg name "$NAME" '.applied = [.applied[] | select(.name != $name)]' \
    "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
  REMOVED=$((REMOVED + 1))
done

if [ "$DRY_RUN" = "true" ]; then
  [ "$REMOVED" -gt 0 ] && echo "$REMOVED hook(s) to remove" >&2
  exit 0
fi

if [ "$REMOVED" -eq 0 ]; then
  exit 0
fi

# Check if any hooks remain
REMAINING=$(jq '.applied | length' "$STATE_FILE")

if [ "$REMAINING" -eq 0 ]; then
  rm -f "$EXT_DIR/hookers.ts"
  echo "Removed $REMOVED hook(s), extension removed" >&2
else
  # Regenerate extension without removed hooks
  trap 'rm -f "$EXT_DIR/hookers.ts.tmp"' ERR
  bash "$MISE_CONFIG_ROOT/scripts/generate-extension.sh" "$STATE_FILE" \
    > "$EXT_DIR/hookers.ts.tmp" \
    && mv "$EXT_DIR/hookers.ts.tmp" "$EXT_DIR/hookers.ts"
  echo "Removed $REMOVED hook(s), extension regenerated ($REMAINING remaining)" >&2
fi
