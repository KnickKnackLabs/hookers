#!/usr/bin/env bash
#MISE description="Remove applied hooks"
#USAGE arg "<hooks...>" help="Hook names to remove (e.g., dashboard anti-compact)"
#USAGE flag "--dry-run" help="Show what would change without removing"
#USAGE flag "--extension-dir <dir>" help="Pi extension directory (default: ~/.pi/agent/extensions)"

set -euo pipefail

DRY_RUN="${usage_dry_run:-false}"
EXT_DIR="${usage_extension_dir:-$HOME/.pi/agent/extensions}"
STATE_DIR="${HOOKERS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/hookers}"
STATE_FILE="$STATE_DIR/applied.json"
HOOKS="$usage_hooks"

if [ ! -f "$STATE_FILE" ]; then
  echo "No hooks applied" >&2
  exit 0
fi

# Validate which hooks are applied
TO_REMOVE=()
for NAME in $HOOKS; do
  IS_APPLIED=$(jq --arg name "$NAME" '[.applied[] | select(.name == $name)] | length' "$STATE_FILE")

  if [ "$IS_APPLIED" -eq 0 ]; then
    echo "Hook '$NAME' is not applied" >&2
    continue
  fi

  if [ "$DRY_RUN" = "true" ]; then
    echo "Would remove: $NAME" >&2
  fi

  TO_REMOVE+=("$NAME")
done

if [ "$DRY_RUN" = "true" ]; then
  [ ${#TO_REMOVE[@]} -gt 0 ] && echo "${#TO_REMOVE[@]} hook(s) to remove" >&2
  exit 0
fi

if [ ${#TO_REMOVE[@]} -eq 0 ]; then
  exit 0
fi

# Build speculative state with hooks removed
SPEC_STATE="${STATE_FILE}.pending"
cp "$STATE_FILE" "$SPEC_STATE"
for NAME in "${TO_REMOVE[@]}"; do
  jq --arg name "$NAME" '.applied = [.applied[] | select(.name != $name)]' \
    "$SPEC_STATE" > "${SPEC_STATE}.tmp" && mv "${SPEC_STATE}.tmp" "$SPEC_STATE"
done

REMAINING=$(jq '.applied | length' "$SPEC_STATE")
trap 'rm -f "$EXT_DIR/hookers.ts.tmp" "$SPEC_STATE" "${SPEC_STATE}.tmp"' ERR

if [ "$REMAINING" -eq 0 ]; then
  # No hooks left — commit state, remove extension
  mv "$SPEC_STATE" "$STATE_FILE"
  rm -f "$EXT_DIR/hookers.ts"
  echo "Removed ${#TO_REMOVE[@]} hook(s), extension removed" >&2
else
  # Generate extension first — if this fails, state is unchanged
  bash "$MISE_CONFIG_ROOT/scripts/generate-extension.sh" "$SPEC_STATE" \
    > "$EXT_DIR/hookers.ts.tmp"

  # Success — commit state and extension
  mv "$SPEC_STATE" "$STATE_FILE"
  mv "$EXT_DIR/hookers.ts.tmp" "$EXT_DIR/hookers.ts"
  echo "Removed ${#TO_REMOVE[@]} hook(s), extension regenerated ($REMAINING remaining)" >&2
fi
