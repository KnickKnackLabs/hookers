#!/usr/bin/env bash
#MISE description="List applied hooks"
#USAGE flag "--json" help="Output raw JSON"

set -euo pipefail

JSON="${usage_json:-false}"
STATE_DIR="${HOOKERS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/hookers}"
STATE_FILE="$STATE_DIR/applied.json"

if [ ! -f "$STATE_FILE" ]; then
  echo "No hooks applied"
  exit 0
fi

HOOK_COUNT=$(jq '.applied | length' "$STATE_FILE" 2>/dev/null)
if [ "$HOOK_COUNT" -eq 0 ]; then
  echo "No hooks applied"
  exit 0
fi

if [ "$JSON" = "true" ]; then
  # Output full catalog entries for applied hooks, resolved from stored paths
  FILES=()
  for i in $(seq 0 $((HOOK_COUNT - 1))); do
    name=$(jq -r ".applied[$i].name" "$STATE_FILE")
    catalog=$(jq -r ".applied[$i].catalog" "$STATE_FILE")
    file="$catalog/${name}.json"
    [ -f "$file" ] && FILES+=("$file")
  done
  if [ ${#FILES[@]} -gt 0 ]; then
    jq -s '.' "${FILES[@]}"
  else
    echo '[]'
  fi
  exit 0
fi

for i in $(seq 0 $((HOOK_COUNT - 1))); do
  name=$(jq -r ".applied[$i].name" "$STATE_FILE")
  catalog=$(jq -r ".applied[$i].catalog" "$STATE_FILE")
  file="$catalog/${name}.json"
  if [ -f "$file" ]; then
    DESC=$(jq -r '.description' "$file")
    ON=$(jq -r '.on' "$file")
    ACTION=$(jq -r '.action' "$file")
    printf "  %-20s %-16s %-8s %s\n" "$name" "$ON" "$ACTION" "$DESC"
  else
    printf "  %-20s %s\n" "$name" "(not found at $catalog)"
  fi
done
