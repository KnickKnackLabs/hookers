#!/usr/bin/env bash
#MISE description="List applied hooks"
#USAGE flag "--json" help="Output raw JSON"

set -euo pipefail

JSON="${usage_json:-false}"
STATE_DIR="${HOOKERS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/hookers}"
STATE_FILE="$STATE_DIR/applied.json"
CATALOG_DIR="${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}/catalog"

if [ ! -f "$STATE_FILE" ]; then
  echo "No hooks applied"
  exit 0
fi

APPLIED=$(jq -r '.applied[]' "$STATE_FILE" 2>/dev/null)
if [ -z "$APPLIED" ]; then
  echo "No hooks applied"
  exit 0
fi

if [ "$JSON" = "true" ]; then
  # Output full catalog entries for applied hooks
  FILES=()
  for name in $APPLIED; do
    file="$CATALOG_DIR/${name}.json"
    [ -f "$file" ] && FILES+=("$file")
  done
  if [ ${#FILES[@]} -gt 0 ]; then
    jq -s '.' "${FILES[@]}"
  else
    echo '[]'
  fi
  exit 0
fi

for name in $APPLIED; do
  file="$CATALOG_DIR/${name}.json"
  if [ -f "$file" ]; then
    DESC=$(jq -r '.description' "$file")
    ON=$(jq -r '.on' "$file")
    ACTION=$(jq -r '.action' "$file")
    printf "  %-20s %-16s %-8s %s\n" "$name" "$ON" "$ACTION" "$DESC"
  else
    printf "  %-20s %s\n" "$name" "(not found in catalog)"
  fi
done
