#!/usr/bin/env bash
#MISE description="Run the status dashboard (outputs a compact status line)"
#USAGE flag "--config <path>" help="Path to dashboard config (default: ~/.config/hookers/dashboard.json)"

set -eu

if [ -n "${usage_config:-}" ]; then
  export HOOKERS_DASHBOARD_CONFIG="$usage_config"
fi

exec bash "${MISE_CONFIG_ROOT:?MISE_CONFIG_ROOT not set}/scripts/dashboard.sh"
